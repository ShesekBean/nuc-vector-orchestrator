# OpenClaw + Signal — environment template
#
# 1. Copy to .env:  cp .env.signal.template .env
# 2. Fill in every REPLACE_ME value.
# 3. NEVER commit .env to git — it contains secrets.
#    Add to .gitignore:  echo ".env" >> .gitignore
#
# Env precedence (highest → lowest):
#   process env → ./.env → ~/.openclaw/.env → openclaw.json `env` block

# ─── Gateway ────────────────────────────────────────────────────────────────
# Where OpenClaw stores config and workspace files on the host.
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# Gateway + bridge ports (host side). Change only if they conflict.
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# "lan" lets the gateway bind to all LAN interfaces inside the container,
# but docker-compose.signal.yml restricts the host port to 127.0.0.1.
# Change to "loopback" for the strictest isolation (control API only on localhost).
OPENCLAW_GATEWAY_BIND=lan

# Docker image built by setup-signal-docker.sh
OPENCLAW_IMAGE=openclaw:signal

# Gateway auth token — MUST be a long random secret.
# Generate one: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# ─── AI provider (set at least one) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME
# GEMINI_API_KEY=REPLACE_ME

# ─── Claude web session (optional — only for web/Claude.ai provider) ────────
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# ─── Extra optional tools ───────────────────────────────────────────────────
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=
# ELEVENLABS_API_KEY=
