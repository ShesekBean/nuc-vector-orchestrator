[Unit]
Description=OpenClaw monthly backup (Ade)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/ophirsw/Documents/claude/openclaw
ExecStart=/home/ophirsw/Documents/claude/openclaw/backup-ade.sh --monthly
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openclaw-ade-backup
