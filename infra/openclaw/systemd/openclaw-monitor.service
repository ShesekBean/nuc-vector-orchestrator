[Unit]
Description=OpenClaw outbound + inbound security monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/sg docker -c "/home/ophirsw/openclaw-dns/openclaw-monitor.sh"
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openclaw-monitor

[Install]
WantedBy=default.target
